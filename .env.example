# Copy to Vercel Project → Settings → Environment Variables (never commit real values).

# Web3Forms — required for the contact form (server-side only).
WEB3FORMS_ACCESS_KEY=

# Optional: lock POST /api/submit-contact to your canonical site origin (e.g. https://www.tarsonlinecafe.work).
CONTACT_ALLOWED_ORIGIN=

# Optional: legacy Discord contact API (/api/contact).
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=
